{
  "name": "react-bytes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently -n \"registry,docs\" -c \"blue,green\" \"npm run registry:dev\" \"vite\"",
    "build": "npm run registry:build && npm run sitemap && npm run llms && vite build && npm run prerender",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "sitemap": "node src/scripts/generateSitemap.js",
    "llms": "node src/scripts/generateLlmsText.js",
    "convert": "node src/scripts/convertToStringExport.js",
    "registry:build": "jsrepo build",
    "prerender": "node src/scripts/prerender.js",
    "registry:dev": "jsrepo build --watch"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@gsap/react": "^2.1.2",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "motion": "^12.40.0",
    "ogl": "^1.0.11",
    "prettier": "^3.8.3",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-haiku": "^2.4.1",
    "react-icons": "^5.6.0",
    "react-router": "^7.15.1",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jsrepo/shadcn": "^7.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsrepo": "^3.7.1",
    "puppeteer": "^25.3.0",
    "vite": "^8.0.12"
  }
}
